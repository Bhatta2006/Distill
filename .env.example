# ── Database (required) ───────────────────────────────────────────────────────
# Local Docker:
DATABASE_URL=postgresql+asyncpg://lucid:lucid@localhost:5432/lucid
# Vercel / production (Neon recommended — has pgvector, free tier):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xyz.us-east-2.aws.neon.tech/neondb?ssl=require

# ── Redis (only needed when USE_CELERY=true, i.e. Docker) ────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Storage ───────────────────────────────────────────────────────────────────
# Local Docker: relative path works
STORAGE_PATH=./data/uploads
# Vercel: /tmp is available within the same function invocation
# STORAGE_PATH=/tmp/lucid-uploads

# ── Deployment mode ───────────────────────────────────────────────────────────
USE_CELERY=true     # Set to false on Vercel (BackgroundTasks replaces Celery)

# ── Embeddings ────────────────────────────────────────────────────────────────
# "local"  → sentence-transformers in-process (Docker only, PyTorch required)
# "voyage" → Voyage AI API (required for Vercel — no PyTorch budget)
EMBEDDING_PROVIDER=local
# EMBEDDING_PROVIDER=voyage
# VOYAGE_API_KEY=pa-...   # from https://dash.voyageai.com (free tier available)

# ── CORS (Vercel production) ───────────────────────────────────────────────────
# FRONTEND_URL=https://distill.vercel.app

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
